{
  "name": "resmu-me",
  "version": "0.0.1",
  "description": "CLI-style career/resume toolkit — author experience in MDX, output to PDF / plain text / web / API via a JS plugin system",
  "type": "module",
  "bin": {
    "resmu": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./plugins/plain": {
      "types": "./dist/plugins/plain/index.d.ts",
      "import": "./dist/plugins/plain/index.js"
    },
    "./plugins/pdf": {
      "types": "./dist/plugins/pdf/index.d.ts",
      "import": "./dist/plugins/pdf/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node ./dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepare": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@inquirer/prompts": "^7.0.0",
    "@mdx-js/mdx": "^3.0.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "kleur": "^4.1.5",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.5",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "resume",
    "cv",
    "mdx",
    "cli",
    "plugin"
  ],
  "license": "MIT"
}
